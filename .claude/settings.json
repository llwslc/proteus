{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh .claude/hooks/pre-commit-diff-hygiene.sh",
            "if": "Bash(git *)",
            "timeout": 30,
            "statusMessage": "diff-hygiene pre-commit check"
          }
        ]
      }
    ]
  }
}
